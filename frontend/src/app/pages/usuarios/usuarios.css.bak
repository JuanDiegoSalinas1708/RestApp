.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #0066cc 0%, #004399 100%);
  color: white;
  padding: 15px 30px;
  margin-bottom: 30px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.navbar h1 {
  margin: 0;
  font-size: 24px;
}

.navbar nav a {
  color: white;
  text-decoration: none;
  margin: 0 15px;
  padding: 8px 12px;
  border-radius: 4px;
  transition: background 0.3s;
}

.navbar nav a:hover {
  background: rgba(255, 255, 255, 0.2);
}

.usuario-info {
  display: flex;
  align-items: center;
  gap: 15px;
}

.usuario-info button {
  background: #ff6b6b;
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.3s;
}

.usuario-info button:hover {
  background: #ff5252;
}

.contenido {
  background: white;
  padding: 30px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.contenido h2 {
  color: #0066cc;
  margin-top: 0;
  border-bottom: 2px solid #0066cc;
  padding-bottom: 10px;
}

table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 20px;
}

table thead {
  background: #f0f0f0;
}

table th {
  padding: 12px;
  text-align: left;
  font-weight: bold;
  color: #0066cc;
  border-bottom: 2px solid #0066cc;
}

table td {
  padding: 12px;
  border-bottom: 1px solid #e0e0e0;
}

table tr:hover {
  background: #f9f9f9;
}

.edit-form {
  background: #f9f9f9;
  padding: 20px;
  border-radius: 8px;
  margin-top: 20px;
  border-left: 4px solid #0066cc;
}

.edit-form h3 {
  margin-top: 0;
  color: #0066cc;
}

.edit-form form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

label {
  display: flex;
  flex-direction: column;
  gap: 5px;
  font-weight: 500;
  color: #333;
}

input, select {
  padding: 8px 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 14px;
  transition: border 0.3s;
}

input:focus, select:focus {
  outline: none;
  border: 1px solid #0066cc;
  box-shadow: 0 0 5px rgba(0, 102, 204, 0.3);
}

button {
  padding: 10px 16px;
  margin-right: 8px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 500;
  transition: background 0.3s;
}

button[type="submit"] {
  background: #0066cc;
  color: white;
}

button[type="submit"]:hover {
  background: #004399;
}

button[type="button"] {
  background: #999;
  color: white;
}

button[type="button"]:hover {
  background: #777;
}

.edit-form button,
table button {
  padding: 6px 12px;
  font-size: 12px;
  margin-right: 4px;
  margin-bottom: 4px;
}

table button:nth-child(1) {
  background: #4CAF50;
  color: white;
}

table button:nth-child(1):hover {
  background: #45a049;
}

table button:nth-child(2) {
  background: #f44336;
  color: white;
}

table button:nth-child(2):hover {
  background: #da190b;
}
